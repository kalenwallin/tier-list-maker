    "@workos/authkit-tanstack-react-start": "^0.11.0",
    "convex": "^1.42.1",
    "html-to-image": "latest",
    "lucide-react": "latest",
    "react": "19.3.0-canary-c0c39a6b-20260709",
    "react-dom": "19.3.0-canary-c0c39a6b-20260709"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tanstack/intent": "^0.3.5",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "wrangler": "^4.110.0"
  },
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
