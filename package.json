{
  "name": "tier-list-maker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "convex dev --start \"vite dev --host 0.0.0.0 --port 3001\"",
    "build": "vite build && tsc --noEmit",
    "build:cloudflare": "vite build && tsc --noEmit",
    "preview": "vite preview --port 3001",
    "deploy": "convex deploy --cmd 'vite build' && wrangler deploy",
    "cf-typegen": "wrangler types --env-file .dev.vars.example --include-runtime=false --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "vite preview --port 3001",
    "lint": "biome lint .",
    "format": "biome format --write ."
  },
