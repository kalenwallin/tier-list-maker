    "@workos/authkit-tanstack-react-start": "^0.11.0",
    "convex": "^1.42.3",
    "html-to-image": "latest",
    "lucide-react": "latest",
    "react": "19.3.0-canary-c0c39a6b-20260709",
    "react-dom": "19.3.0-canary-c0c39a6b-20260709"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
